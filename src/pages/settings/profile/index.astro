---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCurrentSession } from "../../../lib/session";

const session = await getCurrentSession(Astro);
if (!session) {
  return Astro.redirect("/");
}
---
<BaseLayout title="Agora | Profile">
  <main class="mx-auto min-h-screen w-full max-w-xl p-4">
    <section class="rounded-2xl border border-zinc-300 bg-white/90 p-5 text-zinc-900 shadow-sm dark:border-zinc-700 dark:bg-zinc-900/90 dark:text-zinc-100">
      <h1 class="text-xl font-semibold">Profile settings</h1>
      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-200">Change your display nickname without leaving chat.</p>

      <form method="post" action="/api/session/rename" class="mt-4 space-y-3">
        <label class="block text-xs font-medium">New nickname</label>
        <input name="nickname" minlength="2" maxlength="40" required value={session.displayName} class="w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm text-zinc-900 dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100" />
        <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-700">Save</button>
      </form>

      <a href="/rooms" class="mt-5 inline-block text-sm font-medium text-sky-700 hover:text-sky-800 dark:text-sky-300 dark:hover:text-sky-200">Back to rooms</a>
    </section>
  </main>
</BaseLayout>

