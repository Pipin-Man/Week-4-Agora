---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCurrentSession } from "../../../lib/session";

const session = await getCurrentSession(Astro);
if (!session) {
  return Astro.redirect("/");
}
---
<BaseLayout title="Agora | Profile">
  <main class="mx-auto min-h-screen w-full max-w-xl p-4">
    <section class="rounded-2xl border border-zinc-200 bg-white/80 p-5 dark:border-zinc-800 dark:bg-zinc-900/80">
      <h1 class="text-xl font-semibold">Profile settings</h1>
      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">Change your display nickname without leaving chat.</p>

      <form method="post" action="/api/session/rename" class="mt-4 space-y-3">
        <label class="block text-xs font-medium">New nickname</label>
        <input name="nickname" minlength="2" maxlength="40" required value={session.displayName} class="w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
        <button class="rounded-lg bg-zinc-900 px-4 py-2 text-sm font-semibold text-white dark:bg-zinc-100 dark:text-zinc-900">Save</button>
      </form>

      <a href="/chat/lobby" class="mt-5 inline-block text-sm text-sky-600">Back to chat</a>
    </section>
  </main>
</BaseLayout>
