---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Agora | 404">
  <main class="mx-auto flex min-h-screen w-full max-w-xl items-center justify-center p-4">
    <section class="w-full rounded-2xl border border-zinc-200 bg-white/80 p-6 text-center dark:border-zinc-800 dark:bg-zinc-900/80">
      <h1 class="text-xl font-semibold">404</h1>
      <p class="mt-2 text-sm text-zinc-500">The page you requested does not exist.</p>
      <a href="/" class="mt-4 inline-block rounded-lg bg-zinc-900 px-4 py-2 text-sm text-white dark:bg-zinc-100 dark:text-zinc-900">Back home</a>
    </section>
  </main>
</BaseLayout>
