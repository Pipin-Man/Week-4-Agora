---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { copy } from "../../../lib/constants";
import { getPublicOrigin } from "../../../lib/http";
import { renderMessage, renderPresenceFlash } from "../../../lib/render";
import {
  findRoomBySlug,
  joinRoom,
  listOnlineUsers,
  listRecentMessages,
  listRoomsWithOnlineCounts,
  markMentionsSeen,
  unreadMentionCount
} from "../../../lib/rooms";
import { getCurrentSession } from "../../../lib/session";
import { sseHub } from "../../../lib/sse";

const locale = "en" as const;
const currentCopy = copy[locale];

const session = await getCurrentSession(Astro);
if (!session) {
  return Astro.redirect("/");
}

const roomSlug = Astro.params.roomSlug;
if (!roomSlug) {
  return Astro.redirect("/rooms");
}

const room = await findRoomBySlug(roomSlug);
if (!room) {
  Astro.response.status = 404;
}

let onlineUsers: Awaited<ReturnType<typeof listOnlineUsers>> = [];
let messageRows: Awaited<ReturnType<typeof listRecentMessages>> = [];
let mentionCount = 0;

if (room) {
  const wasNewJoin = await joinRoom(room.id, session.id);
  void markMentionsSeen(session.id, room.id);

  if (wasNewJoin) {
    sseHub.publish({
      roomId: room.id,
      event: "presence:flash",
      html: renderPresenceFlash(`${session.displayName} joined the room`)
    });
  }

  [onlineUsers, messageRows, mentionCount] = await Promise.all([
    listOnlineUsers(room.id),
    listRecentMessages(room.id, 40),
    unreadMentionCount(session.id)
  ]);
}

const orderedMessages = [...messageRows].reverse();
const configuredOrigin = (import.meta.env.PUBLIC_APP_URL || "").trim();
const requestOrigin = getPublicOrigin(Astro.request, Astro.url.origin);
const publicOrigin = (configuredOrigin || requestOrigin || Astro.url.origin).replace(/\/$/, "");
const inviteLink = room ? `${publicOrigin}/join/${room.slug}` : "";
const onlineNames = onlineUsers.map((user) => user.displayName);
const rooms = await listRoomsWithOnlineCounts();
---
<BaseLayout title={`Agora | ${room?.name ?? "Not Found"}`}>
  {room ? (
    <div x-data="{ inviteOpen: false }" class="h-screen">
      <main class="mx-auto flex h-screen w-full max-w-7xl flex-col gap-3 p-3 pb-44 md:p-4 md:pb-32">
        <header class="rounded-2xl border border-zinc-200 bg-white/70 px-3 py-3 backdrop-blur dark:border-zinc-700 dark:bg-zinc-900/80 md:px-4">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <h1 class="truncate text-2xl font-bold tracking-tight md:text-[1.9rem]">#{room.name}</h1>
              <p class="mt-1 truncate text-xs text-zinc-600 dark:text-zinc-300">{room.description || "No description"}</p>
              <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-zinc-600 dark:text-zinc-300">
                <span><span id="room-members-count">{onlineUsers.length}</span> in the room</span>
                <button type="button" class="rounded-lg border border-zinc-300 px-2 py-1 text-xs font-semibold text-zinc-700 hover:bg-zinc-100 dark:border-zinc-600 dark:text-zinc-100 dark:hover:bg-zinc-800" @click="inviteOpen = true" title="Invite to room" aria-label="Invite to room">Invite to room</button>
                <button id="mobile-members-toggle" type="button" class="rounded border border-zinc-300 px-2 py-1 text-[11px] text-zinc-700 hover:bg-zinc-100 dark:border-zinc-600 dark:text-zinc-200 dark:hover:bg-zinc-800 md:hidden">Members</button>
              </div>
            </div>

            <div class="flex items-center gap-2">
              <div class="relative">
                <div id="mention-bell-wrap">
                  <button id="mention-bell" type="button" aria-label="Notifications" class="relative inline-flex size-8 items-center justify-center rounded-lg border border-zinc-300 text-zinc-700 dark:border-zinc-700 dark:text-zinc-200">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17H18l-1.405-1.405A2.03 2.03 0 0 1 16 14.158V11a6.002 6.002 0 0 0-4-5.659V4a2 2 0 1 0-4 0v1.341C5.67 6.165 4 8.388 4 11v3.159c0 .538-.214 1.055-.595 1.436L2 17h3.143M9 17a3 3 0 0 0 6 0" />
                    </svg>
                    {mentionCount > 0 && <span class="absolute -right-1 -top-1 min-w-4 rounded-full bg-red-500 px-1 text-center text-[10px] leading-4 text-white">{mentionCount}</span>}
                  </button>
                </div>

                <div id="notifications-panel" class="absolute right-0 top-10 z-50 hidden w-[min(88vw,22rem)] overflow-hidden rounded-xl border border-zinc-300 bg-white text-zinc-900 shadow-2xl dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100">
                  <div class="flex h-11 items-center justify-between border-b border-zinc-200 px-3 dark:border-zinc-700">
                    <h3 class="text-sm font-semibold">Notifications</h3>
                    <button id="notifications-close" type="button" class="text-xs text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100">Close</button>
                  </div>
                  <ul id="notifications-list" class="max-h-72 overflow-y-auto">
                    <li class="px-3 py-3 text-xs text-zinc-500 dark:text-zinc-400">No unread notifications</li>
                  </ul>
                </div>
              </div>

              <div class="relative">
                <button id="user-menu-toggle" type="button" class="inline-flex items-center gap-2 rounded-lg border border-zinc-300 px-2 py-1 text-sm font-semibold text-zinc-800 hover:bg-zinc-100 dark:border-zinc-600 dark:text-zinc-100 dark:hover:bg-zinc-800">
                  <span class="size-2.5 rounded-full" style={`background:${session.color}`}></span>
                  <span class="max-w-44 truncate">{session.displayName}</span>
                  <svg viewBox="0 0 20 20" fill="currentColor" class="size-3 opacity-70"><path d="M5.5 7.5 10 12l4.5-4.5" /></svg>
                </button>
                <div id="user-menu" class="absolute right-0 top-10 z-50 hidden w-52 rounded-xl border border-zinc-300 bg-white p-1 text-zinc-900 shadow-xl dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100">
                  <a href="/settings/profile" class="block rounded-lg px-3 py-2 text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800">Change nickname</a>
                  <form method="post" action="/api/session/logout">
                    <button type="submit" class="mt-1 w-full rounded-lg px-3 py-2 text-left text-sm text-rose-600 hover:bg-rose-50 dark:text-rose-300 dark:hover:bg-rose-950/30">Log out</button>
                  </form>
                </div>
              </div>

              <div class="relative">
                <button id="app-menu-toggle" type="button" aria-label="App settings" class="inline-flex size-8 items-center justify-center rounded-lg border border-zinc-300 text-zinc-700 hover:bg-zinc-100 dark:border-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-800">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 15.5A3.5 3.5 0 1 0 12 8.5a3.5 3.5 0 0 0 0 7Zm7-3.5a7.7 7.7 0 0 0-.11-1.3l2.01-1.57-2-3.46-2.42.79a7.7 7.7 0 0 0-2.24-1.3L13.9 2h-3.8l-.34 2.46a7.7 7.7 0 0 0-2.24 1.3l-2.42-.79-2 3.46 2.01 1.57A7.7 7.7 0 0 0 5 12c0 .44.04.87.11 1.3L3.1 14.87l2 3.46 2.42-.79c.68.54 1.44.98 2.24 1.3L10.1 22h3.8l.34-2.46c.8-.32 1.56-.76 2.24-1.3l2.42.79 2-3.46-2.01-1.57c.07-.43.11-.86.11-1.3Z" />
                  </svg>
                </button>
                <div id="app-menu" class="absolute right-0 top-10 z-50 hidden w-52 rounded-xl border border-zinc-300 bg-white p-1 text-zinc-900 shadow-xl dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100">
                  <a href="/rooms" class="block rounded-lg px-3 py-2 text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800">Back to rooms</a>
                  <button id="theme-toggle-menu" type="button" class="mt-1 w-full rounded-lg px-3 py-2 text-left text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800">Theme: Light</button>
                  <button id="sound-toggle-menu" type="button" class="mt-1 w-full rounded-lg px-3 py-2 text-left text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800">Sound: On</button>
                </div>
              </div>
            </div>
          </div>
        </header>

        <div id="mobile-members-panel" class="hidden rounded-2xl border border-zinc-300 bg-white/80 p-3 dark:border-zinc-700 dark:bg-zinc-900/85 md:hidden">
          <h2 class="text-sm font-semibold">{currentCopy.online}</h2>
          <ul id="mobile-online-list" class="mt-2 space-y-2">
            {onlineUsers.length > 0 ? (
              onlineUsers.map((user) => (
                <li data-online="1" data-user-name={user.displayName} class="flex items-center gap-2 text-sm">
                  <span class="size-2 rounded-full" style={`background:${user.color}`}></span>
                  <button type="button" data-mention-name={user.displayName} class="truncate text-left hover:underline">{user.displayName}</button>
                </li>
              ))
            ) : (
              <li data-empty="1" class="text-xs text-zinc-500 dark:text-zinc-400">No one online yet</li>
            )}
          </ul>
        </div>

        <section class="grid min-h-0 flex-1 gap-3 md:[grid-template-columns:minmax(0,1fr)_clamp(190px,28vw,260px)] lg:[grid-template-columns:clamp(220px,22vw,280px)_minmax(0,1fr)_clamp(190px,20vw,240px)]">
          <aside id="rooms-sidebar" class="hidden min-h-0 flex-col rounded-2xl border border-zinc-300 bg-white/85 dark:border-zinc-700 dark:bg-zinc-900/85 lg:flex">
            <div class="flex h-12 items-center justify-between border-b border-zinc-200 px-3 dark:border-zinc-700">
              <h2 class="text-sm font-semibold">Rooms</h2>
              <a href="/rooms" class="text-xs text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100">Manage</a>
            </div>
            <div class="min-h-0 flex-1 overflow-y-auto p-2">
              <ul class="space-y-1">
                {rooms.map((item) => (
                  <li>
                    <a
                      href={`/chat/${item.slug}`}
                      class:list={[
                        "block rounded-lg px-2 py-2",
                        item.id === room.id
                          ? "bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900"
                          : "hover:bg-zinc-100 dark:hover:bg-zinc-800"
                      ]}
                    >
                      <p class="truncate text-sm font-semibold">{item.name}</p>
                      <p class="mt-0.5 truncate text-[11px] opacity-80">{item.description || "No description"}</p>
                      <p data-room-count-for={item.id} class="mt-1 text-[11px] opacity-75">{item.onlineCount} in the room</p>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>

          <section class="flex min-h-0 flex-col rounded-2xl border border-zinc-300 bg-white/85 dark:border-zinc-700 dark:bg-zinc-900/85">
            <div id="presence-flash" class="px-3 pt-3"></div>
            <div id="message-scroll" class="min-h-0 flex-1 overflow-y-auto px-4 py-3">
              <ul id="message-list" hx-swap="beforeend" class="space-y-1">
                {orderedMessages.length === 0 && (
                  <li id="empty-room-hint" class="text-center text-xs text-zinc-500 dark:text-zinc-400">{currentCopy.emptyRoom}</li>
                )}
                {orderedMessages.map((msg) => (
                  <Fragment
                    set:html={renderMessage({
                      id: msg.id,
                      type: msg.type,
                      body: msg.body,
                      displayName: msg.displayName,
                      color: msg.color,
                      createdAt: new Date(msg.createdAt)
                    })}
                  />
                ))}
              </ul>
            </div>
            <div id="typing-indicator" class="h-8 border-t border-zinc-200 px-4 py-2 text-xs text-zinc-500 dark:border-zinc-700 dark:text-zinc-300"></div>
          </section>

          <aside id="online-sidebar" class="hidden min-h-0 flex-col rounded-2xl border border-zinc-300 bg-white/80 dark:border-zinc-700 dark:bg-zinc-900/80 md:flex">
            <div class="flex h-12 items-center justify-between border-b border-zinc-200 px-3 dark:border-zinc-800">
              <h2 class="text-sm font-semibold">{currentCopy.online}</h2>
              <span id="online-count" class="text-xs text-zinc-500 dark:text-zinc-400">{onlineUsers.length}</span>
            </div>
            <div class="min-h-0 flex-1 overflow-y-auto p-3">
              <ul id="online-list" class="space-y-2">
                {onlineUsers.length > 0 ? (
                  onlineUsers.map((user) => (
                    <li data-online="1" data-user-name={user.displayName} class="flex items-center gap-2 text-sm">
                      <span class="size-2 rounded-full" style={`background:${user.color}`}></span>
                      <button type="button" data-mention-name={user.displayName} class="truncate text-left hover:underline">{user.displayName}</button>
                    </li>
                  ))
                ) : (
                  <li data-empty="1" class="text-xs text-zinc-500 dark:text-zinc-400">No one online yet</li>
                )}
              </ul>
            </div>
          </aside>
        </section>
      </main>

      <footer class="fixed inset-x-0 bottom-0 z-40 border-t border-zinc-300 bg-white/98 pb-[env(safe-area-inset-bottom)] backdrop-blur dark:border-zinc-700 dark:bg-zinc-900/96">
        <div class="mx-auto w-full max-w-7xl px-3 py-3 md:px-4">
          <section class="rounded-xl border border-zinc-300 bg-white px-3 py-2 dark:border-zinc-700 dark:bg-zinc-900">
            <form id="composer" method="post" action={`/api/rooms/${room.id}/messages`} hx-post={`/api/rooms/${room.id}/messages`} hx-swap="none">
              <textarea id="message-input" name="body" required minlength="1" maxlength="1200" rows="2" placeholder="Write a message..." class="w-full rounded-xl border border-zinc-300 px-3 py-2 text-base text-zinc-900 md:text-sm dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100"></textarea>
              <div id="mention-suggestions" class="mt-1 hidden rounded-lg border border-zinc-300 bg-white p-2 text-xs dark:border-zinc-600 dark:bg-zinc-800"></div>
              <div class="mt-2 flex items-center justify-between">
                <p class="text-[11px] text-zinc-500">Use @username or @everyone</p>
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white">Send</button>
              </div>
            </form>
          </section>
        </div>
      </footer>

      <div x-show="inviteOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4" @click.self="inviteOpen = false">
        <div class="w-full max-w-md rounded-2xl border border-zinc-300 bg-white p-4 text-zinc-900 shadow-2xl dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100">
          <h3 class="text-lg font-semibold">Invite friend</h3>
          <p class="mt-1 text-xs text-zinc-500">Share this link:</p>
          <input id="invite-link" readonly value={inviteLink} class="mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-xs text-zinc-900 dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100" />
          <div class="mt-3 flex justify-end gap-2">
            <button class="rounded-lg border border-zinc-300 px-3 py-1 text-sm dark:border-zinc-700" @click="navigator.clipboard.writeText(document.getElementById('invite-link').value)">Copy</button>
            <button class="rounded-lg bg-zinc-900 px-3 py-1 text-sm text-white dark:bg-zinc-100 dark:text-zinc-900" @click="inviteOpen = false">Close</button>
          </div>
        </div>
      </div>
    </div>
  ) : (
    <main class="mx-auto flex min-h-screen w-full max-w-xl items-center justify-center p-4">
      <section class="w-full rounded-2xl border border-zinc-200 bg-white/80 p-6 text-center dark:border-zinc-800 dark:bg-zinc-900/80">
        <h1 class="text-xl font-semibold">Room not found</h1>
        <p class="mt-2 text-sm text-zinc-500">This room does not exist or the invite is invalid.</p>
        <a href="/rooms" class="mt-4 inline-block rounded-lg bg-zinc-900 px-4 py-2 text-sm text-white dark:bg-zinc-100 dark:text-zinc-900">Go to Rooms</a>
      </section>
    </main>
  )}

  {room && (
    <script is:inline define:vars={{ roomId: room.id, onlineNames, sessionName: session.displayName }}>
      const form = document.getElementById("composer");
      const input = document.getElementById("message-input");
      const suggestionBox = document.getElementById("mention-suggestions");
      const messageList = document.getElementById("message-list");
      const messageScroll = document.getElementById("message-scroll");
      const typingIndicator = document.getElementById("typing-indicator");
      const onlineList = document.getElementById("online-list");
      const mobileOnlineList = document.getElementById("mobile-online-list");
      const onlineCountNode = document.getElementById("online-count");
      const roomMembersCountNode = document.getElementById("room-members-count");
      const presenceFlash = document.getElementById("presence-flash");

      const bellWrap = document.getElementById("mention-bell-wrap");
      const notificationsPanel = document.getElementById("notifications-panel");
      const notificationsList = document.getElementById("notifications-list");
      const notificationsClose = document.getElementById("notifications-close");

      const userMenuToggle = document.getElementById("user-menu-toggle");
      const userMenu = document.getElementById("user-menu");
      const appMenuToggle = document.getElementById("app-menu-toggle");
      const appMenu = document.getElementById("app-menu");
      const themeToggleMenu = document.getElementById("theme-toggle-menu");
      const soundToggleMenu = document.getElementById("sound-toggle-menu");

      const mobileMembersToggle = document.getElementById("mobile-members-toggle");
      const mobileMembersPanel = document.getElementById("mobile-members-panel");

      let typingTimer;
      let presenceFlashTimer;
      let notificationsOpen = false;
      let notificationsLoading = false;
      let onlineNamePool = Array.isArray(onlineNames) ? [...onlineNames] : [];

      function postTyping(typing) {
        fetch(`/api/rooms/${roomId}/typing`, {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams({ typing: typing ? "1" : "0" }).toString()
        }).catch(() => {});
      }

      function scrollMessagesToBottom() {
        if (!(messageScroll instanceof HTMLElement)) return;
        messageScroll.scrollTop = messageScroll.scrollHeight;
      }

      function syncOnlineCount() {
        const source = onlineList instanceof HTMLElement ? onlineList : mobileOnlineList;
        if (!(source instanceof HTMLElement)) return;

        const entries = Array.from(source.querySelectorAll('li[data-online="1"]'));
        const names = entries
          .map((entry) => {
            if (!(entry instanceof HTMLElement)) return "";
            const attrName = entry.dataset.userName?.trim() || "";
            if (attrName) return attrName;
            const label = entry.querySelector('[data-mention-name], span:last-child');
            return label instanceof HTMLElement ? label.textContent?.trim() || "" : "";
          })
          .filter(Boolean);

        onlineNamePool = names;

        if (onlineCountNode instanceof HTMLElement) {
          onlineCountNode.textContent = String(entries.length);
        }

        if (roomMembersCountNode instanceof HTMLElement) {
          roomMembersCountNode.textContent = String(entries.length);
        }

        document.querySelectorAll(`[data-room-count-for="${roomId}"]`).forEach((node) => {
          if (node instanceof HTMLElement) {
            node.textContent = `${entries.length} in the room`;
          }
        });
      }

      function closeMenus() {
        userMenu?.classList.add("hidden");
        appMenu?.classList.add("hidden");
      }

      async function refreshBell() {
        if (!(bellWrap instanceof HTMLElement)) return;

        try {
          const response = await fetch("/api/session/mention-bell", {
            headers: { "HX-Request": "true" }
          });

          if (!response.ok) return;
          bellWrap.innerHTML = await response.text();
        } catch {
          // Keep current bell state if network fails.
        }
      }

      async function loadNotifications() {
        if (!(notificationsList instanceof HTMLElement) || notificationsLoading) return;
        notificationsLoading = true;
        notificationsList.innerHTML = '<li class="px-3 py-3 text-xs text-zinc-500 dark:text-zinc-400">Loading...</li>';

        try {
          const response = await fetch("/api/session/notifications", {
            headers: { "HX-Request": "true" }
          });

          if (!response.ok) {
            notificationsList.innerHTML = '<li class="px-3 py-3 text-xs text-rose-600 dark:text-rose-300">Could not load notifications</li>';
            return;
          }

          notificationsList.innerHTML = await response.text();
        } catch {
          notificationsList.innerHTML = '<li class="px-3 py-3 text-xs text-rose-600 dark:text-rose-300">Could not load notifications</li>';
        } finally {
          notificationsLoading = false;
        }
      }

      function setNotificationsOpen(next) {
        if (!(notificationsPanel instanceof HTMLElement)) return;
        notificationsOpen = next;
        notificationsPanel.classList.toggle("hidden", !next);

        if (next) {
          closeMenus();
          void loadNotifications();
        }
      }

      function insertMention(name) {
        if (!(input instanceof HTMLTextAreaElement)) return;
        const cursor = input.selectionStart || input.value.length;
        const head = input.value.slice(0, cursor);
        const tail = input.value.slice(cursor);
        const replaced = head.replace(/@([a-zA-Z0-9_]*)$/, `@${name} `);
        input.value = `${replaced}${tail}`;
        input.focus();
        suggestionBox?.classList.add("hidden");
      }

      function bindMentionFromList(root) {
        if (!(root instanceof HTMLElement)) return;

        root.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const mentionNode = target.closest("[data-mention-name]");
          if (!(mentionNode instanceof HTMLElement)) return;
          const name = mentionNode.dataset.mentionName;
          if (!name) return;
          event.preventDefault();
          insertMention(name);
        });
      }

      function updateMentionSuggestions() {
        if (!(input instanceof HTMLTextAreaElement) || !(suggestionBox instanceof HTMLElement)) return;
        const cursor = input.selectionStart || input.value.length;
        const head = input.value.slice(0, cursor);
        const match = head.match(/(^|\s)@([a-zA-Z0-9_]*)$/);

        if (!match) {
          suggestionBox.classList.add("hidden");
          suggestionBox.innerHTML = "";
          return;
        }

        const query = match[2].toLowerCase();
        const base = ["everyone", ...onlineNamePool.filter((name) => name.toLowerCase() !== sessionName.toLowerCase())];
        const candidates = base.filter((name) => name.toLowerCase().startsWith(query)).slice(0, 6);

        if (!candidates.length) {
          suggestionBox.classList.add("hidden");
          suggestionBox.innerHTML = "";
          return;
        }

        suggestionBox.innerHTML = candidates
          .map((name) => `<button type="button" data-name="${name}" class="mr-1 mb-1 rounded border border-zinc-300 px-2 py-1 text-xs dark:border-zinc-700">@${name}</button>`)
          .join("");
        suggestionBox.classList.remove("hidden");
      }

      input?.addEventListener("input", () => {
        postTyping(true);
        updateMentionSuggestions();
        clearTimeout(typingTimer);
        typingTimer = setTimeout(() => postTyping(false), 1200);
      });

      bindMentionFromList(onlineList);
      bindMentionFromList(mobileOnlineList);

      suggestionBox?.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLButtonElement)) return;
        const name = target.dataset.name;
        if (name) {
          insertMention(name);
        }
      });

      form?.addEventListener("submit", () => {
        setTimeout(() => {
          if (input instanceof HTMLTextAreaElement) {
            input.value = "";
          }
          if (suggestionBox instanceof HTMLElement) {
            suggestionBox.classList.add("hidden");
            suggestionBox.innerHTML = "";
          }
          postTyping(false);
        }, 10);
      });

      bellWrap?.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const button = target.closest("#mention-bell");
        if (!button) return;

        event.preventDefault();
        setNotificationsOpen(!notificationsOpen);
      });

      notificationsClose?.addEventListener("click", () => {
        setNotificationsOpen(false);
      });

      userMenuToggle?.addEventListener("click", () => {
        if (!(userMenu instanceof HTMLElement)) return;
        const willOpen = userMenu.classList.contains("hidden");
        closeMenus();
        setNotificationsOpen(false);
        userMenu.classList.toggle("hidden", !willOpen);
      });

      appMenuToggle?.addEventListener("click", () => {
        if (!(appMenu instanceof HTMLElement)) return;
        const willOpen = appMenu.classList.contains("hidden");
        closeMenus();
        setNotificationsOpen(false);
        appMenu.classList.toggle("hidden", !willOpen);
      });

      mobileMembersToggle?.addEventListener("click", () => {
        if (!(mobileMembersPanel instanceof HTMLElement)) return;
        mobileMembersPanel.classList.toggle("hidden");
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Node)) return;

        if (notificationsOpen && !(notificationsPanel?.contains(target) || bellWrap?.contains(target))) {
          setNotificationsOpen(false);
        }

        if (!(userMenu?.contains(target) || userMenuToggle?.contains(target))) {
          userMenu?.classList.add("hidden");
        }

        if (!(appMenu?.contains(target) || appMenuToggle?.contains(target))) {
          appMenu?.classList.add("hidden");
        }
      });

      setInterval(() => {
        fetch(`/api/presence/ping?roomId=${roomId}`, { method: "POST" }).catch(() => {});
      }, 25000);

      setInterval(() => {
        void refreshBell();
      }, 20000);

      const themeApi = window.agoraTheme;
      if (themeApi && themeToggleMenu instanceof HTMLButtonElement) {
        const paintTheme = () => {
          themeToggleMenu.textContent = `Theme: ${themeApi.enabled ? "Dark" : "Light"}`;
        };

        paintTheme();
        themeToggleMenu.addEventListener("click", () => {
          themeApi.toggle();
          paintTheme();
        });
      }

      const soundApi = window.agoraSound;
      if (soundApi && soundToggleMenu instanceof HTMLButtonElement) {
        const paintSound = () => {
          soundToggleMenu.textContent = `Sound: ${soundApi.enabled ? "On" : "Off"}`;
        };

        paintSound();
        soundToggleMenu.addEventListener("click", () => {
          soundApi.set(!soundApi.enabled);
          paintSound();
        });
      }

      syncOnlineCount();
      scrollMessagesToBottom();
      void refreshBell();

      const events = new EventSource(`/api/rooms/${roomId}/events`);

      const appendMessage = (payload) => {
        if (!messageList || !(payload instanceof MessageEvent)) return;
        const emptyHint = document.getElementById("empty-room-hint");
        if (emptyHint) emptyHint.remove();

        messageList.insertAdjacentHTML("beforeend", payload.data);
        scrollMessagesToBottom();

        if (window.agoraSound && typeof window.agoraSound.play === "function") {
          window.agoraSound.play();
        }
      };

      events.addEventListener("message:new", appendMessage);
      events.addEventListener("system:new", appendMessage);

      events.addEventListener("typing:update", (event) => {
        if (typingIndicator && event instanceof MessageEvent) {
          typingIndicator.innerHTML = event.data;
        }
      });

      events.addEventListener("presence:update", (event) => {
        if (event instanceof MessageEvent) {
          if (onlineList instanceof HTMLElement) {
            onlineList.innerHTML = event.data;
          }
          if (mobileOnlineList instanceof HTMLElement) {
            mobileOnlineList.innerHTML = event.data;
          }
          syncOnlineCount();
        }
      });

      events.addEventListener("presence:flash", (event) => {
        if (presenceFlash && event instanceof MessageEvent) {
          presenceFlash.innerHTML = event.data;
          clearTimeout(presenceFlashTimer);
          presenceFlashTimer = setTimeout(() => {
            presenceFlash.innerHTML = "";
          }, 6500);
        }
      });

      events.addEventListener("mention:notify", () => {
        void refreshBell();
        if (notificationsOpen) {
          void loadNotifications();
        }
      });

      window.addEventListener("beforeunload", () => {
        clearTimeout(presenceFlashTimer);
        events.close();
      });
    </script>
  )}
</BaseLayout>
