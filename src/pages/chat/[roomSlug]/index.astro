---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { copy } from "../../../lib/constants";
import { renderMessage, renderPresenceFlash } from "../../../lib/render";
import {
  findRoomBySlug,
  findUserNicknameById,
  joinRoom,
  listOnlineUsers,
  listRecentMessages,
  listRooms,
  markMentionsSeen,
  unreadMentionCount
} from "../../../lib/rooms";
import { getCurrentSession } from "../../../lib/session";
import { sseHub } from "../../../lib/sse";

const locale = "en" as const;
const currentCopy = copy[locale];

const session = await getCurrentSession(Astro);
if (!session) {
  return Astro.redirect("/");
}

const roomSlug = Astro.params.roomSlug;
if (!roomSlug) {
  return Astro.redirect("/chat/lobby");
}

const room = await findRoomBySlug(roomSlug);
if (!room) {
  Astro.response.status = 404;
}

const roomsPromise = listRooms();
const mentionCountPromise = unreadMentionCount(session.id);
const roomCreatorPromise = room?.createdBy ? findUserNicknameById(room.createdBy) : Promise.resolve<string | null>(null);

let onlineUsers: Awaited<ReturnType<typeof listOnlineUsers>> = [];
let messageRows: Awaited<ReturnType<typeof listRecentMessages>> = [];

if (room) {
  const wasNewJoin = await joinRoom(room.id, session.id);
  void markMentionsSeen(session.id, room.id);

  if (wasNewJoin) {
    sseHub.publish({
      roomId: room.id,
      event: "presence:flash",
      html: renderPresenceFlash(`${session.displayName} joined the room`)
    });
  }

  [onlineUsers, messageRows] = await Promise.all([
    listOnlineUsers(room.id),
    listRecentMessages(room.id, 40)
  ]);
}

const [rooms, mentionCount, roomCreator] = await Promise.all([roomsPromise, mentionCountPromise, roomCreatorPromise]);
const orderedMessages = [...messageRows].reverse();
const inviteLink = room ? `${Astro.url.origin}/join/${room.slug}` : "";
const onlineNames = onlineUsers.map((user) => user.displayName);
const creatorLabel = roomCreator || "Community";
---
<BaseLayout title={`Agora | ${room?.name ?? "Not Found"}`}>
  {room ? (
    <div x-data="{ inviteOpen: false, roomOpen: false }" class="h-screen">
      <main class="mx-auto flex h-screen w-full max-w-7xl flex-col gap-3 p-3 pb-44 md:p-4 md:pb-36">
        <header class="flex items-center justify-between rounded-2xl border border-zinc-200 bg-white/70 px-4 py-3 backdrop-blur dark:border-zinc-800 dark:bg-zinc-900/70">
          <div>
            <h1 class="text-lg font-semibold">Agora</h1>
            <p class="text-xs text-zinc-500 dark:text-zinc-400">Room #{room.name}</p>
          </div>

          <button id="sound-toggle" type="button" class="rounded-lg border border-zinc-300 px-3 py-1 text-xs dark:border-zinc-700">Sound: On</button>
        </header>

        <section class="grid min-h-0 flex-1 gap-3 md:grid-cols-[260px_1fr_240px]">
          <aside class="flex min-h-0 flex-col rounded-2xl border border-zinc-200 bg-white/75 dark:border-zinc-800 dark:bg-zinc-900/75">
            <div class="flex h-14 items-center justify-between border-b border-zinc-200 px-4 dark:border-zinc-800">
              <h2 class="text-lg font-semibold">Rooms</h2>
              <button type="button" class="text-xs text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100" @click="roomOpen = true">Add Room</button>
            </div>
            <div class="min-h-0 flex-1 overflow-y-auto p-3">
              <ul class="space-y-1">
                {rooms.map((item) => (
                  <li>
                    <a
                      href={`/chat/${item.slug}`}
                      class:list={[
                        "block rounded-lg px-3 py-2 text-sm",
                        item.id === room.id
                          ? "bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900"
                          : "hover:bg-zinc-100 dark:hover:bg-zinc-800"
                      ]}
                    >
                      {item.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>

          <section class="flex min-h-0 flex-col rounded-2xl border border-zinc-200 bg-white/80 dark:border-zinc-800 dark:bg-zinc-900/80">
            <div class="flex h-14 items-center justify-between border-b border-zinc-200 px-4 dark:border-zinc-800">
              <h2 class="text-lg font-semibold">#{room.name}</h2>
              <p class="text-xs text-zinc-500 dark:text-zinc-400">Created by {creatorLabel}</p>
            </div>

            <div id="message-scroll" class="min-h-0 flex-1 overflow-y-auto px-4 py-3">
              <ul id="message-list" hx-swap="beforeend" class="space-y-1">
                {orderedMessages.length === 0 && (
                  <li id="empty-room-hint" class="text-center text-xs text-zinc-500 dark:text-zinc-400">{currentCopy.emptyRoom}</li>
                )}
                {orderedMessages.map((msg) => (
                  <Fragment
                    set:html={renderMessage({
                      id: msg.id,
                      type: msg.type,
                      body: msg.body,
                      displayName: msg.displayName,
                      color: msg.color,
                      createdAt: new Date(msg.createdAt)
                    })}
                  />
                ))}
              </ul>
            </div>

            <div id="typing-indicator" class="h-8 border-t border-zinc-200 px-4 py-2 text-xs text-zinc-500 dark:border-zinc-800 dark:text-zinc-400"></div>
          </section>

          <aside class="flex min-h-0 flex-col rounded-2xl border border-zinc-200 bg-white/75 dark:border-zinc-800 dark:bg-zinc-900/75">
            <div class="flex h-14 items-center justify-between border-b border-zinc-200 px-4 dark:border-zinc-800">
              <h2 class="text-lg font-semibold">{currentCopy.online}</h2>
              <span id="online-count" class="text-xs text-zinc-500 dark:text-zinc-400">{onlineUsers.length}</span>
            </div>
            <div id="presence-flash" class="px-3 pt-2"></div>
            <div class="min-h-0 flex-1 overflow-y-auto p-3 pt-2">
              <ul id="online-list" class="space-y-2">
                {onlineUsers.length > 0 ? (
                  onlineUsers.map((user) => (
                    <li data-online="1" class="flex items-center gap-2 text-sm">
                      <span class="size-2 rounded-full" style={`background:${user.color}`}></span>
                      <span>{user.displayName}</span>
                    </li>
                  ))
                ) : (
                  <li data-empty="1" class="text-xs text-zinc-500 dark:text-zinc-400">No one online yet</li>
                )}
              </ul>
            </div>
          </aside>
        </section>
      </main>

      <footer class="fixed inset-x-0 bottom-0 z-40 border-t border-zinc-200 bg-white/95 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/95">
        <div class="mx-auto grid w-full max-w-7xl gap-3 px-3 py-3 md:grid-cols-[33%_1fr] md:px-4">
          <section class="relative rounded-xl border border-zinc-200 bg-white px-3 py-2 dark:border-zinc-800 dark:bg-zinc-900">
            <div class="flex items-start justify-between gap-2">
              <div>
                <p class="text-[11px] text-zinc-500 dark:text-zinc-400">Connected as</p>
                <p class="text-sm font-bold">{session.displayName}</p>
              </div>

              <div class="relative">
                <div id="mention-bell-wrap">
                  <button id="mention-bell" type="button" aria-label="Notifications" class="relative inline-flex size-8 items-center justify-center rounded-lg border border-zinc-300 text-zinc-700 dark:border-zinc-700 dark:text-zinc-200">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17H18l-1.405-1.405A2.03 2.03 0 0 1 16 14.158V11a6.002 6.002 0 0 0-4-5.659V4a2 2 0 1 0-4 0v1.341C5.67 6.165 4 8.388 4 11v3.159c0 .538-.214 1.055-.595 1.436L2 17h3.143M9 17a3 3 0 0 0 6 0" />
                    </svg>
                    {mentionCount > 0 && <span class="absolute -right-1 -top-1 min-w-4 rounded-full bg-red-500 px-1 text-center text-[10px] leading-4 text-white">{mentionCount}</span>}
                  </button>
                </div>

                <div id="notifications-panel" class="absolute bottom-10 right-0 z-50 hidden w-[min(92vw,28rem)] overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-2xl dark:border-zinc-800 dark:bg-zinc-900">
                  <div class="flex h-11 items-center justify-between border-b border-zinc-200 px-3 dark:border-zinc-800">
                    <h3 class="text-sm font-semibold">Notifications</h3>
                    <button id="notifications-close" type="button" class="text-xs text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100">Close</button>
                  </div>
                  <ul id="notifications-list" class="max-h-80 overflow-y-auto">
                    <li class="px-3 py-3 text-xs text-zinc-500 dark:text-zinc-400">No unread notifications</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="mt-2 flex flex-wrap items-center gap-3 text-xs">
              <a href="/settings/profile" class="text-sky-700 hover:underline dark:text-sky-300">Change name</a>
              <button type="button" class="text-sky-700 hover:underline dark:text-sky-300" @click="inviteOpen = true">{currentCopy.invite}</button>
              <form method="post" action="/api/session/logout">
                <button class="text-rose-600 hover:underline dark:text-rose-300">Logout</button>
              </form>
            </div>
          </section>

          <section class="rounded-xl border border-zinc-200 bg-white px-3 py-2 dark:border-zinc-800 dark:bg-zinc-900">
            <form id="composer" method="post" action={`/api/rooms/${room.id}/messages`} hx-post={`/api/rooms/${room.id}/messages`} hx-swap="none">
              <textarea id="message-input" name="body" required minlength="1" maxlength="1200" rows="2" placeholder="Write a message..." class="w-full rounded-xl border border-zinc-300 px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950"></textarea>
              <div id="mention-suggestions" class="mt-1 hidden rounded-lg border border-zinc-200 bg-white p-2 text-xs dark:border-zinc-700 dark:bg-zinc-900"></div>
              <div class="mt-2 flex items-center justify-between">
                <p class="text-[11px] text-zinc-500">Use @username or @everyone</p>
                <button class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white">Send</button>
              </div>
            </form>
          </section>
        </div>
      </footer>

      <div x-show="inviteOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4" @click.self="inviteOpen = false">
        <div class="w-full max-w-md rounded-2xl bg-white p-4 dark:bg-zinc-900">
          <h3 class="text-lg font-semibold">Invite friend</h3>
          <p class="mt-1 text-xs text-zinc-500">Share this link:</p>
          <input id="invite-link" readonly value={inviteLink} class="mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-xs dark:border-zinc-700 dark:bg-zinc-950" />
          <div class="mt-3 flex justify-end gap-2">
            <button class="rounded-lg border border-zinc-300 px-3 py-1 text-sm dark:border-zinc-700" @click="navigator.clipboard.writeText(document.getElementById('invite-link').value)">Copy</button>
            <button class="rounded-lg bg-zinc-900 px-3 py-1 text-sm text-white dark:bg-zinc-100 dark:text-zinc-900" @click="inviteOpen = false">Close</button>
          </div>
        </div>
      </div>

      <div x-show="roomOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4" @click.self="roomOpen = false">
        <div class="w-full max-w-md rounded-2xl bg-white p-4 dark:bg-zinc-900">
          <h3 class="text-lg font-semibold">Add room</h3>
          <form method="post" action="/api/rooms" class="mt-3 space-y-2">
            <input name="name" required minlength="2" maxlength="80" placeholder="Room name" class="w-full rounded-md border border-zinc-300 px-2 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
            <input name="description" maxlength="120" placeholder="Description (optional)" class="w-full rounded-md border border-zinc-300 px-2 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
            <div class="mt-3 flex justify-end gap-2">
              <button type="button" class="rounded-lg border border-zinc-300 px-3 py-1 text-sm dark:border-zinc-700" @click="roomOpen = false">Cancel</button>
              <button class="rounded-lg bg-zinc-900 px-3 py-1 text-sm text-white dark:bg-zinc-100 dark:text-zinc-900">Create</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  ) : (
    <main class="mx-auto flex min-h-screen w-full max-w-xl items-center justify-center p-4">
      <section class="w-full rounded-2xl border border-zinc-200 bg-white/80 p-6 text-center dark:border-zinc-800 dark:bg-zinc-900/80">
        <h1 class="text-xl font-semibold">Room not found</h1>
        <p class="mt-2 text-sm text-zinc-500">This room does not exist or the invite is invalid.</p>
        <a href="/chat/lobby" class="mt-4 inline-block rounded-lg bg-zinc-900 px-4 py-2 text-sm text-white dark:bg-zinc-100 dark:text-zinc-900">Go to Lobby</a>
      </section>
    </main>
  )}

  {room && (
    <script is:inline define:vars={{ roomId: room.id, onlineNames, sessionName: session.displayName }}>
      const form = document.getElementById("composer");
      const input = document.getElementById("message-input");
      const suggestionBox = document.getElementById("mention-suggestions");
      const soundToggle = document.getElementById("sound-toggle");
      const messageList = document.getElementById("message-list");
      const messageScroll = document.getElementById("message-scroll");
      const typingIndicator = document.getElementById("typing-indicator");
      const onlineList = document.getElementById("online-list");
      const onlineCountNode = document.getElementById("online-count");
      const presenceFlash = document.getElementById("presence-flash");
      const bellWrap = document.getElementById("mention-bell-wrap");
      const notificationsPanel = document.getElementById("notifications-panel");
      const notificationsList = document.getElementById("notifications-list");
      const notificationsClose = document.getElementById("notifications-close");

      let typingTimer;
      let presenceFlashTimer;
      let notificationsOpen = false;
      let notificationsLoading = false;
      let onlineNamePool = Array.isArray(onlineNames) ? [...onlineNames] : [];

      function postTyping(typing) {
        fetch(`/api/rooms/${roomId}/typing`, {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams({ typing: typing ? "1" : "0" }).toString()
        }).catch(() => {});
      }

      function scrollMessagesToBottom() {
        if (!(messageScroll instanceof HTMLElement)) return;
        messageScroll.scrollTop = messageScroll.scrollHeight;
      }

      function insertMention(name) {
        if (!(input instanceof HTMLTextAreaElement)) return;
        const cursor = input.selectionStart || input.value.length;
        const head = input.value.slice(0, cursor);
        const tail = input.value.slice(cursor);
        const replaced = head.replace(/@([a-zA-Z0-9_]*)$/, `@${name} `);
        input.value = `${replaced}${tail}`;
        input.focus();
        suggestionBox?.classList.add("hidden");
      }

      function updateMentionSuggestions() {
        if (!(input instanceof HTMLTextAreaElement) || !suggestionBox) return;
        const cursor = input.selectionStart || input.value.length;
        const head = input.value.slice(0, cursor);
        const match = head.match(/(^|\s)@([a-zA-Z0-9_]*)$/);

        if (!match) {
          suggestionBox.classList.add("hidden");
          suggestionBox.innerHTML = "";
          return;
        }

        const query = match[2].toLowerCase();
        const base = ["everyone", ...onlineNamePool.filter((name) => name.toLowerCase() !== sessionName.toLowerCase())];
        const candidates = base.filter((name) => name.toLowerCase().startsWith(query)).slice(0, 6);

        if (!candidates.length) {
          suggestionBox.classList.add("hidden");
          suggestionBox.innerHTML = "";
          return;
        }

        suggestionBox.innerHTML = candidates
          .map(
            (name) =>
              `<button type="button" data-name="${name}" class="mr-1 mb-1 rounded border border-zinc-300 px-2 py-1 text-xs dark:border-zinc-700">@${name}</button>`
          )
          .join("");
        suggestionBox.classList.remove("hidden");
      }

      function syncOnlineCount() {
        if (!onlineList || !onlineCountNode) return;
        const entries = Array.from(onlineList.querySelectorAll('li[data-online="1"]'));
        const names = entries
          .map((entry) => {
            const label = entry.querySelector("span:last-child");
            return label instanceof HTMLElement ? label.textContent?.trim() || "" : "";
          })
          .filter(Boolean);

        onlineNamePool = names;
        onlineCountNode.textContent = String(entries.length);
      }

      async function refreshBell() {
        if (!bellWrap) return;

        try {
          const response = await fetch("/api/session/mention-bell", {
            headers: { "HX-Request": "true" }
          });

          if (!response.ok) return;
          bellWrap.innerHTML = await response.text();
        } catch {
          // Keep current bell state if network fails.
        }
      }

      async function loadNotifications() {
        if (!notificationsList || notificationsLoading) return;
        notificationsLoading = true;
        notificationsList.innerHTML = '<li class="px-3 py-3 text-xs text-zinc-500 dark:text-zinc-400">Loading...</li>';

        try {
          const response = await fetch("/api/session/notifications", {
            headers: { "HX-Request": "true" }
          });

          if (!response.ok) {
            notificationsList.innerHTML = '<li class="px-3 py-3 text-xs text-rose-600 dark:text-rose-300">Could not load notifications</li>';
            return;
          }

          notificationsList.innerHTML = await response.text();
        } catch {
          notificationsList.innerHTML = '<li class="px-3 py-3 text-xs text-rose-600 dark:text-rose-300">Could not load notifications</li>';
        } finally {
          notificationsLoading = false;
        }
      }

      function setNotificationsOpen(next) {
        if (!(notificationsPanel instanceof HTMLElement)) return;
        notificationsOpen = next;
        notificationsPanel.classList.toggle("hidden", !next);

        if (next) {
          void loadNotifications();
        }
      }

      input?.addEventListener("input", () => {
        postTyping(true);
        updateMentionSuggestions();
        clearTimeout(typingTimer);
        typingTimer = setTimeout(() => postTyping(false), 1200);
      });

      suggestionBox?.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLButtonElement)) return;
        const name = target.dataset.name;
        if (name) {
          insertMention(name);
        }
      });

      form?.addEventListener("submit", () => {
        setTimeout(() => {
          if (input instanceof HTMLTextAreaElement) {
            input.value = "";
          }
          if (suggestionBox) {
            suggestionBox.classList.add("hidden");
            suggestionBox.innerHTML = "";
          }
          postTyping(false);
        }, 10);
      });

      bellWrap?.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest("#mention-bell");
        if (!button) return;

        event.preventDefault();
        setNotificationsOpen(!notificationsOpen);
      });

      notificationsClose?.addEventListener("click", () => {
        setNotificationsOpen(false);
      });

      document.addEventListener("click", (event) => {
        if (!notificationsOpen) return;
        const target = event.target;
        if (!(target instanceof Node)) return;

        if (notificationsPanel?.contains(target) || bellWrap?.contains(target)) {
          return;
        }

        setNotificationsOpen(false);
      });

      setInterval(() => {
        fetch(`/api/presence/ping?roomId=${roomId}`, { method: "POST" }).catch(() => {});
      }, 25000);

      setInterval(() => {
        void refreshBell();
      }, 20000);

      const soundApi = window.agoraSound;
      if (soundToggle && soundApi) {
        const paintSound = () => {
          soundToggle.textContent = `Sound: ${soundApi.enabled ? "On" : "Off"}`;
        };

        paintSound();
        soundToggle.addEventListener("click", () => {
          soundApi.set(!soundApi.enabled);
          paintSound();
        });
      }

      syncOnlineCount();
      scrollMessagesToBottom();
      void refreshBell();

      const events = new EventSource(`/api/rooms/${roomId}/events`);

      const appendMessage = (payload) => {
        if (!messageList || !(payload instanceof MessageEvent)) return;
        const emptyHint = document.getElementById("empty-room-hint");
        if (emptyHint) emptyHint.remove();

        messageList.insertAdjacentHTML("beforeend", payload.data);
        scrollMessagesToBottom();

        if (window.agoraSound && typeof window.agoraSound.play === "function") {
          window.agoraSound.play();
        }
      };

      events.addEventListener("message:new", appendMessage);
      events.addEventListener("system:new", appendMessage);

      events.addEventListener("typing:update", (event) => {
        if (typingIndicator && event instanceof MessageEvent) {
          typingIndicator.innerHTML = event.data;
        }
      });

      events.addEventListener("presence:update", (event) => {
        if (onlineList && event instanceof MessageEvent) {
          onlineList.innerHTML = event.data;
          syncOnlineCount();
        }
      });

      events.addEventListener("presence:flash", (event) => {
        if (presenceFlash && event instanceof MessageEvent) {
          presenceFlash.innerHTML = event.data;
          clearTimeout(presenceFlashTimer);
          presenceFlashTimer = setTimeout(() => {
            presenceFlash.innerHTML = "";
          }, 6500);
        }
      });

      events.addEventListener("mention:notify", () => {
        void refreshBell();
        if (notificationsOpen) {
          void loadNotifications();
        }
      });

      window.addEventListener("beforeunload", () => {
        clearTimeout(presenceFlashTimer);
        events.close();
      });
    </script>
  )}
</BaseLayout>


